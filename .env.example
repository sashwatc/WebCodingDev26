PORT=5001

# Optional: if provided, found items are stored in MongoDB.
# If omitted, the backend uses the local seeded item store.
# MONGO_URI=mongodb://127.0.0.1:27017/lost-then-found

# Optional: use only when building the frontend for a separately hosted API.
# Leave blank for same-origin deployments where the Node server serves the frontend and /api routes together.
# VITE_API_BASE_URL=https://your-api.example.com
