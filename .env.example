# Spring Boot API URL for split frontend/backend deployments.
# For local Vite dev, leave this blank and let Vite proxy /api to http://127.0.0.1:8080.
# Do not include /api at the end.
# VITE_API_URL=http://localhost:8080

# Optional for npm run ts. Used by the Spring Boot backend auto-start.
# Keep the real value in .env.local, not in git.
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/lostthenfound?retryWrites=true&w=majority&appName=LostThenFound
# MONGO_DATABASE=lostthenfound
