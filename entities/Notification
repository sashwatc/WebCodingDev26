{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "match_found",
        "claim_update",
        "item_approved",
        "item_returned",
        "admin_action",
        "system"
      ],
      "default": "system"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "link": {
      "type": "string",
      "description": "Optional link to navigate to"
    },
    "related_item_id": {
      "type": "string"
    }
  },
  "required": [
    "user_email",
    "title",
    "message"
  ]
}